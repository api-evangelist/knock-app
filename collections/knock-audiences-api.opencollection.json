{
  "opencollection": "1.0.0",
  "info": {
    "name": "Knock Audiences API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Audiences",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List members",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.knock.app/v1/audiences/:key/members",
            "params": [
              {
                "name": "key",
                "value": "",
                "type": "path",
                "description": "The key of the audience."
              }
            ]
          },
          "docs": "Returns a paginated list of members for the specified audience."
        },
        {
          "info": {
            "name": "Add members",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.knock.app/v1/audiences/:key/members",
            "params": [
              {
                "name": "key",
                "value": "",
                "type": "path",
                "description": "The key of the audience."
              },
              {
                "name": "create_audience",
                "value": "",
                "type": "query",
                "description": "Create the audience if it does not exist."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Adds one or more members to the specified audience."
        },
        {
          "info": {
            "name": "Remove members",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.knock.app/v1/audiences/:key/members",
            "params": [
              {
                "name": "key",
                "value": "",
                "type": "path",
                "description": "The key of the audience."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Removes one or more members from the specified audience."
        }
      ]
    }
  ],
  "bundled": true
}